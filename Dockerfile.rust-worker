FROM rust:1.86-slim-bookworm AS builder

WORKDIR /app
COPY rust-worker /app/rust-worker
RUN cd /app/rust-worker && cargo build --release

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/rust-worker/target/release/lunaris-worker /usr/local/bin/lunaris-worker

CMD ["lunaris-worker"]

